# ============================================
# AI Automated Hiring Software - Backend
# Environment Variables for Render Deployment
# ============================================
# Copy this file and fill in your values.
# Do NOT commit the filled-in version to Git.

# --- TiDB Cloud Database ---
SPRING_DATASOURCE_URL=jdbc:mysql://<TIDB_HOST>:4000/<DATABASE>?sslMode=VERIFY_IDENTITY
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# --- JWT Authentication ---
JWT_SECRET=

# --- Server ---
PORT=8080

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=production

# --- Frontend CORS ---
FRONTEND_URL=https://your-frontend.vercel.app

# --- Application Mode ---
APP_DEMO_MODE=false

# --- JPA/Hibernate ---
JPA_DDL_AUTO=update
