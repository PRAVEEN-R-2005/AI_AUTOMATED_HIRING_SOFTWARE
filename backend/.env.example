# Port for the Express backend server to listen on
PORT=8080

# Environment mode (production, development, test)
NODE_ENV=production

# Database Connection Pool Settings
# Standard TCP configuration:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_root_password_here
DB_NAME=hr_hiring_system

# Alternatively, configure via a single connection URL:
# DATABASE_URL=mysql://root:password@localhost:3306/hr_hiring_system

# Google Cloud SQL socket connection path (Required for Cloud Run Unix socket connectivity):
# DB_SOCKET_PATH=/cloudsql/your-project-id:your-region:your-sql-instance-name

# Database SSL configuration (Set to true to force SSL for remote MySQL providers like Aiven or TiDB)
DB_SSL=true

# JWT Configuration (Required in Production)
JWT_SECRET=your_jwt_secret_key_here

# Demo bypassing credentials config (Optional, defaults to false)
DEMO_MODE=false

# Frontend URL (CORS Production Origin, e.g., https://your-app.vercel.app)
FRONTEND_URL=https://your-app.vercel.app

# Optional integrations
# SMTP_HOST=
# SENDGRID_API_KEY=
